# Copy to .env for local dev, and set the same values in the Vercel dashboard
# (Project → Settings → Environment Variables) for the deployed app.

# --- Database (PostgreSQL) ---
# Use a POOLED connection string (Neon/Supabase/Vercel Postgres) for serverless.
# Example (Neon): postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Auth ---
# Sign session cookies. Generate a long random value, e.g.:  openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"

# --- Multi-tenant routing ---
# On Vercel's free domain, set ROOT_DOMAIN to your app host and use PATH routing,
# because wildcard subdomains (*.vercel.app) are not available.
NEXT_PUBLIC_ROOT_DOMAIN="your-app.vercel.app"
# "path" -> /s/<tenant>  (works on *.vercel.app)   |   "subdomain" -> <tenant>.<domain> (needs custom domain + wildcard DNS)
NEXT_PUBLIC_TENANT_ROUTING="path"

# --- WhatsApp alerts ---
# "log" prints alerts to the server logs (visible in Vercel → Deployment → Functions logs).
# Switch to "meta" + fill the IDs to send real WhatsApp messages.
WHATSAPP_PROVIDER="log"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_TEMPLATE_NAME="feedback_alert"
